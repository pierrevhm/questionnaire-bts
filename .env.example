# ══════════════════════════════════════════════════
# CONFIGURATION EMAIL — BTS Business School
# ══════════════════════════════════════════════════
# 1. Copiez ce fichier et renommez-le en ".env"
# 2. Remplissez les valeurs ci-dessous
# ══════════════════════════════════════════════════


# ── Adresse qui REÇOIT les dossiers ─────────────
EMAIL_DESTINATAIRE=secretariat@votre-ecole.fr


# ── Configuration SMTP ───────────────────────────

# --- Option A : Gmail ---
# Activez d'abord l'accès "Mots de passe des applications" sur votre compte Google :
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre.adresse@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx   # mot de passe d'application (16 caractères)

# --- Option B : Outlook / Office 365 ---
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=votre.adresse@outlook.com
# SMTP_PASS=votre_mot_de_passe

# --- Option C : OVH / autre hébergeur ---
# SMTP_HOST=ssl0.ovh.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=contact@votre-domaine.fr
# SMTP_PASS=votre_mot_de_passe


# ── Port du serveur (optionnel, défaut : 3000) ───
PORT=3000
